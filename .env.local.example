# ============================================================
# kabu-dashboard 環境変数テンプレート
# このファイルを .env.local にコピーして値を入力してください
# ============================================================

# ── J-Quants API キー（Vercel 環境変数にも同じ名前で設定）────
# これを設定すると、ユーザーが個別に API キーを入力しなくてもよくなります
JQUANTS_API_KEY=your_jquants_api_key_here

# ── Supabase（https://app.supabase.com → プロジェクト設定 → API）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── AIアシスト（✨ことばで追加・テーマでさがす）────────────────
# kabu 専用の Gemini API キーを発行して設定（reflect-web と無料枠を食い合わないため別キー推奨）
GEMINI_API_KEY=your_gemini_api_key_here
# 任意: モデル上書き（既定 gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash
# 任意: AI利用の全ユーザー合計の日次上限（既定300。コスト暴走の最終防衛線）
# AI_DAILY_GLOBAL_CAP=300
# 任意: service role キー（グローバル日次上限の集計に使用。無くてもユーザー別上限は機能する）
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
