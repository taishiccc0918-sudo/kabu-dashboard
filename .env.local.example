# ============================================================
# kabu-dashboard 環境変数テンプレート
# このファイルを .env.local にコピーして値を入力してください
# ============================================================

# ── J-Quants API キー（Vercel 環境変数にも同じ名前で設定）────
# これを設定すると、ユーザーが個別に API キーを入力しなくてもよくなります
JQUANTS_API_KEY=your_jquants_api_key_here

# ── Supabase（https://app.supabase.com → プロジェクト設定 → API）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
